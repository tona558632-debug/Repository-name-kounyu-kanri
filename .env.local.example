# ============================================================
# 購入品・在庫管理アプリ 環境変数サンプル
# このファイルを `.env.local` にコピーして値を埋めてください
# ============================================================

# Supabase（クライアント・サーバ両方で使用）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# サーバ側のみ（Server Action / Route Handler / Migration用）
# このキーは絶対にクライアントに渡さないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 型生成用（npm run supabase:gen-types で使用）
SUPABASE_PROJECT_REF=xxxxxxxxxxxx

# アプリ動作設定
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 出品候補の閾値（日数）。未設定時はアプリ側のデフォルト180日を使用
LISTING_CANDIDATE_THRESHOLD_DAYS=180

# スクリーンショットAI解析（claude-haiku使用）
# https://console.anthropic.com/settings/keys でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-...

# 後追い: Sentry（任意）
# NEXT_PUBLIC_SENTRY_DSN=
